#!/usr/bin/python3
"""Upload a file to an S3-compatible endpoint and print the public URL.

Reads config from ~/.config/capture/s3.conf (shell-sourceable KEY=value).
Required: S3_ENDPOINT, S3_BUCKET, S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY
Optional: S3_REGION (default: auto), S3_PATH_PREFIX, S3_PUBLIC_URL_BASE, S3_ACL

Exit 0 on success (URL on stdout); 1 = config error; 2 = upload error.
Uses only the Python standard library (SigV4 signed via hashlib/hmac).
"""
import datetime, hashlib, hmac, os, sys, urllib.error, urllib.parse, urllib.request

CONFIG = os.path.expanduser('~/.config/capture/s3.conf')

MIME = {
    '.png':  'image/png',
    '.jpg':  'image/jpeg',  '.jpeg': 'image/jpeg',
    '.gif':  'image/gif',
    '.webp': 'image/webp',
    '.mp4':  'video/mp4',
    '.webm': 'video/webm',
    '.mkv':  'video/x-matroska',
}


def die(msg, code=1):
    sys.stderr.write(f'capture-upload: {msg}\n')
    sys.exit(code)


def load_config():
    if not os.path.isfile(CONFIG):
        die(f'config missing: {CONFIG}\n'
            f'Run `simple-screen-capture --setup` to configure S3/R2 upload.')
    cfg = {}
    for line in open(CONFIG):
        line = line.strip()
        if not line or line.startswith('#') or '=' not in line:
            continue
        k, _, v = line.partition('=')
        cfg[k.strip()] = v.strip().strip('"').strip("'")
    for req in ('S3_ENDPOINT', 'S3_BUCKET', 'S3_ACCESS_KEY_ID', 'S3_SECRET_ACCESS_KEY'):
        if not cfg.get(req):
            die(f'missing {req} in {CONFIG}')
    return cfg


def signing_key(secret, date, region, service):
    k = ('AWS4' + secret).encode('utf-8')
    for msg in (date, region, service, 'aws4_request'):
        k = hmac.new(k, msg.encode('utf-8'), hashlib.sha256).digest()
    return k


def upload(cfg, path):
    with open(path, 'rb') as f:
        data = f.read()
    payload_hash = hashlib.sha256(data).hexdigest()

    endpoint = cfg['S3_ENDPOINT'].rstrip('/')
    bucket   = cfg['S3_BUCKET']
    region   = cfg.get('S3_REGION') or 'auto'
    prefix   = cfg.get('S3_PATH_PREFIX', '')
    acl      = cfg.get('S3_ACL', '')
    key_id   = cfg['S3_ACCESS_KEY_ID']
    secret   = cfg['S3_SECRET_ACCESS_KEY']
    public   = cfg.get('S3_PUBLIC_URL_BASE', '').rstrip('/')

    ext   = os.path.splitext(path)[1].lower()
    ctype = MIME.get(ext, 'application/octet-stream')

    object_key    = f'{prefix}{os.path.basename(path)}'
    parsed        = urllib.parse.urlparse(endpoint)
    host          = parsed.netloc
    canonical_uri = f'/{bucket}/{urllib.parse.quote(object_key, safe="/")}'
    upload_url    = f'{parsed.scheme}://{host}{canonical_uri}'

    now        = datetime.datetime.now(datetime.timezone.utc)
    amz_date   = now.strftime('%Y%m%dT%H%M%SZ')
    date_stamp = now.strftime('%Y%m%d')

    headers = {
        'Host':                 host,
        'Content-Type':         ctype,
        'X-Amz-Content-Sha256': payload_hash,
        'X-Amz-Date':           amz_date,
    }
    if acl:
        headers['X-Amz-Acl'] = acl

    sorted_names      = sorted(headers.keys(), key=str.lower)
    canonical_headers = ''.join(f'{h.lower()}:{headers[h].strip()}\n' for h in sorted_names)
    signed_headers    = ';'.join(h.lower() for h in sorted_names)

    canonical_request = '\n'.join([
        'PUT',
        canonical_uri,
        '',
        canonical_headers,
        signed_headers,
        payload_hash,
    ])

    scope          = f'{date_stamp}/{region}/s3/aws4_request'
    string_to_sign = '\n'.join([
        'AWS4-HMAC-SHA256',
        amz_date,
        scope,
        hashlib.sha256(canonical_request.encode('utf-8')).hexdigest(),
    ])

    key       = signing_key(secret, date_stamp, region, 's3')
    signature = hmac.new(key, string_to_sign.encode('utf-8'), hashlib.sha256).hexdigest()

    headers['Authorization'] = (
        f'AWS4-HMAC-SHA256 Credential={key_id}/{scope}, '
        f'SignedHeaders={signed_headers}, Signature={signature}'
    )

    req = urllib.request.Request(upload_url, data=data, method='PUT', headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=60) as r:
            r.read()
    except urllib.error.HTTPError as e:
        body = e.read().decode('utf-8', 'replace')[:400]
        die(f'HTTP {e.code}: {body}', 2)
    except Exception as e:
        die(f'upload failed: {e}', 2)

    if public:
        print(f'{public}/{urllib.parse.quote(object_key, safe="/")}')
    else:
        print(upload_url)


if __name__ == '__main__':
    if len(sys.argv) != 2:
        die('usage: capture-upload <file>')
    upload(load_config(), sys.argv[1])
