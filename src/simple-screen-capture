#!/usr/bin/env bash
# simple-screen-capture — screenshot · GIF · screencast with integrated capture panel

set -uo pipefail

PLATFORM=$(uname -s)  # Darwin or Linux
SCRIPT_DIR="$(cd "$(dirname "$0")" 2>/dev/null && pwd)"

# When invoked from Hammerspoon / Automator / Services, PATH is stripped down
# and Homebrew-installed binaries (ffmpeg, terminal-notifier, optipng) are
# invisible. Add the standard Homebrew locations so dependency checks pass.
if [[ "$PLATFORM" == "Darwin" ]]; then
  export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:$PATH"
fi

if [[ "$PLATFORM" == "Linux" ]]; then
  export DISPLAY="${DISPLAY:-:0}"
  export XAUTHORITY="${XAUTHORITY:-$HOME/.Xauthority}"
fi

CONFIG_DIR="$HOME/.config/capture"
SCREENSHOTS_DIR="$HOME/Pictures/Screenshots"
if [[ "$PLATFORM" == "Darwin" ]]; then
  SCREENCASTS_DIR="$HOME/Movies/Screencasts"
else
  SCREENCASTS_DIR="$HOME/Videos/Screencasts"
fi
SLICES_DIR="$SCREENSHOTS_DIR/slices"

mkdir -p "$CONFIG_DIR" "$SCREENSHOTS_DIR" "$SCREENCASTS_DIR"

# ── dependency check ──────────────────────────────────────────────────────────
if [[ "$PLATFORM" == "Darwin" ]]; then
  MISSING=()
  for cmd in ffmpeg; do
    command -v "$cmd" &>/dev/null || MISSING+=("$cmd")
  done
  if (( ${#MISSING[@]} )); then
    MSG="capture: missing ${MISSING[*]} — install: brew install ${MISSING[*]}"
    osascript -e "display notification \"$MSG\" with title \"capture\"" 2>/dev/null || true
    echo "$MSG" >&2
    exit 1
  fi
else
  MISSING=()
  for cmd in maim ffmpeg xclip optipng; do
    command -v "$cmd" &>/dev/null || MISSING+=("$cmd")
  done
  if (( ${#MISSING[@]} )); then
    MSG="capture: missing ${MISSING[*]} — install: sudo apt install ${MISSING[*]}"
    command -v notify-send &>/dev/null && notify-send "capture" "$MSG" -t 6000
    echo "$MSG" >&2
    exit 1
  fi
fi

# ── notify helper ─────────────────────────────────────────────────────────────
# On macOS, banners are attributed to "Script Editor" / "Script Monitor"; enable
# that bundle in System Settings → Notifications if the banners aren't visible.
# Prefer terminal-notifier if installed (brew install terminal-notifier) —
# it posts under its own bundle ID and is easier to grant permission to.
say() {
  if [[ "$PLATFORM" == "Darwin" ]]; then
    if command -v terminal-notifier &>/dev/null; then
      terminal-notifier -title "$1" -message "$2" &>/dev/null && return
    fi
    osascript -e "display notification \"$2\" with title \"$1\"" 2>/dev/null || true
  else
    command -v notify-send &>/dev/null && notify-send "$1" "$2" -t "${3:-3000}" || true
  fi
}

# ── clipboard helper ──────────────────────────────────────────────────────────
clip_text() {
  if [[ "$PLATFORM" == "Darwin" ]]; then
    printf '%s' "$1" | pbcopy
  else
    printf '%s' "$1" | xclip -selection clipboard
  fi
}

clip_image() {
  local file="$1"
  if [[ "$PLATFORM" == "Darwin" ]]; then
    osascript -e "set the clipboard to (read (POSIX file \"$file\") as «class PNGf»)" 2>/dev/null
  else
    xclip -selection clipboard -t image/png < "$file"
  fi
}

clip_base64() {
  local file="$1"
  if [[ "$PLATFORM" == "Darwin" ]]; then
    base64 -i "$file" | pbcopy
  else
    base64 -w 0 "$file" | xclip -selection clipboard
  fi
}

# ── macOS display helpers ─────────────────────────────────────────────────────
_MAC_SCALE=""
mac_display_scale() {
  if [[ -z "$_MAC_SCALE" ]]; then
    local tmp; tmp=$(mktemp /tmp/scale-XXXXXX.png)
    screencapture -x -R "0,0,100,100" "$tmp" 2>/dev/null
    _MAC_SCALE=$(python3 - <<'EOF'
import struct, sys, os
path = sys.argv[1] if len(sys.argv) > 1 else ""
try:
    with open(path, 'rb') as f:
        f.read(16)
        w = struct.unpack('>I', f.read(4))[0]
    print(w // 100)
except Exception:
    print(1)
EOF
"$tmp" 2>/dev/null || echo 1)
    rm -f "$tmp"
    _MAC_SCALE="${_MAC_SCALE:-1}"
  fi
  echo "$_MAC_SCALE"
}

_MAC_SCREEN_IDX=""
mac_screen_index() {
  if [[ -z "$_MAC_SCREEN_IDX" ]]; then
    _MAC_SCREEN_IDX=$(ffmpeg -f avfoundation -list_devices true -i "" 2>&1 | \
      awk '/\[AVF/ && /[Cc]apture [Ss]creen/{match($0,/\[([0-9]+)\]/,a); if(a[1]!="") {print a[1]; exit}}')
    _MAC_SCREEN_IDX="${_MAC_SCREEN_IDX:-1}"
  fi
  echo "$_MAC_SCREEN_IDX"
}

# ── upload helper ─────────────────────────────────────────────────────────────
upload_and_clip() {
  local file="$1" label="$2"
  local url err
  say "$label" "Uploading…" 20000
  if ! url=$("${SCRIPT_DIR}/capture-upload" "$file" 2>/tmp/capture-upload.err); then
    err=$(cat /tmp/capture-upload.err 2>/dev/null)
    say "$label" "Upload failed — ${err:-unknown error}" 8000
    return 1
  fi
  clip_text "$url"
  say "$label" "URL copied — $url" 6000
}

# ── stop panel ────────────────────────────────────────────────────────────────
wait_for_stop() {
  sleep 0.4
  "${SCRIPT_DIR}/capture-stop" "$1"
}

# ── smart slice ───────────────────────────────────────────────────────────────
do_smart_slice() {
  local video="$1"
  local ts="$2"
  local threshold="${3:-0.07}"
  local outdir="$SLICES_DIR/$ts"
  mkdir -p "$outdir"

  say "Smart Slice" "Analysing recording…" 20000

  ffmpeg -i "$video" \
    -vf "select='eq(n\,0)+gt(scene\,${threshold})*gte(t-prev_selected_t\,0.5)',setpts=N/TB" \
    -vsync vfr \
    -q:v 2 \
    "$outdir/slice_%04d.png" \
    -loglevel quiet 2>/dev/null

  local count
  count=$(find "$outdir" -name 'slice_*.png' 2>/dev/null | wc -l)

  if (( count == 0 )); then
    ffmpeg -i "$video" -frames:v 1 "$outdir/slice_0001.png" -loglevel quiet 2>/dev/null || true
    count=1
  fi

  say "Smart Slice" "${count} screenshot$([ "$count" -ne 1 ] && echo s) saved → slices/${ts}" 8000
}

# ── screenshot ────────────────────────────────────────────────────────────────
do_screenshot() {
  local clipboard_mode="$1" X="$2" Y="$3" W="$4" H="$5"
  local tmp ts out
  tmp=$(mktemp /tmp/capture-XXXXXX.png)
  ts=$(date +%Y-%m-%d_%H-%M-%S)
  out="$SCREENSHOTS_DIR/${ts}.png"
  trap 'rm -f "$tmp"' RETURN

  if [[ "$PLATFORM" == "Darwin" ]]; then
    screencapture -x -R "${X},${Y},${W},${H}" "$tmp" 2>/dev/null || return
  else
    maim -g "${W}x${H}+${X}+${Y}" "$tmp" 2>/dev/null || return
  fi

  local orig comp pct
  orig=$(wc -c < "$tmp")
  command -v optipng &>/dev/null && optipng -quiet -o2 "$tmp"
  comp=$(wc -c < "$tmp")
  pct=$(( (orig - comp) * 100 / orig ))

  cp "$tmp" "$out"

  case "$clipboard_mode" in
    url)    upload_and_clip "$out" "Screenshot" ;;
    base64) clip_base64 "$tmp"; say "Screenshot" "Base64 copied — ${comp}B (−${pct}%)" ;;
    *)      clip_image  "$tmp"; say "Screenshot" "Image copied — ${comp}B (−${pct}%)"  ;;
  esac
}

# ── gif ───────────────────────────────────────────────────────────────────────
do_gif() {
  local clipboard_mode="$1" smart_slice="$2" threshold="$3" X="$4" Y="$5" W="$6" H="$7"
  local tmp palette ts out
  tmp=$(mktemp /tmp/capture-XXXXXX.mp4)
  palette=$(mktemp /tmp/capture-XXXXXX.png)
  ts=$(date +%Y-%m-%d_%H-%M-%S)
  out="$SCREENCASTS_DIR/${ts}.gif"

  [[ $W -lt 2 || $H -lt 2 ]] && return

  if [[ "$PLATFORM" == "Darwin" ]]; then
    local scale screen_idx px py pw ph
    scale=$(mac_display_scale)
    screen_idx=$(mac_screen_index)
    px=$(( X * scale )); py=$(( Y * scale ))
    pw=$(( W * scale )); ph=$(( H * scale ))
    ffmpeg -f avfoundation -r 15 -i "${screen_idx}" \
      -filter:v "crop=${pw}:${ph}:${px}:${py}" \
      -vcodec libx264 -preset ultrafast -crf 0 "$tmp" -y -loglevel quiet &
  else
    ffmpeg -f x11grab -r 15 -s "${W}x${H}" -i "${DISPLAY}+${X},${Y}" \
      -vcodec libx264 -preset ultrafast -crf 0 "$tmp" -y -loglevel quiet &
  fi
  local fpid=$!

  wait_for_stop "Recording GIF"
  kill "$fpid" 2>/dev/null; wait "$fpid" 2>/dev/null || true

  say "Capture" "Converting to GIF…" 30000

  ffmpeg -i "$tmp" \
    -vf "fps=15,scale=${W}:-1:flags=lanczos,palettegen=stats_mode=diff" \
    "$palette" -y -loglevel quiet

  ffmpeg -i "$tmp" -i "$palette" \
    -filter_complex "fps=15,scale=${W}:-1:flags=lanczos[x];[x][1:v]paletteuse=dither=bayer:bayer_scale=5:diff_mode=rectangle" \
    "$out" -y -loglevel quiet

  [[ "$smart_slice" == "1" ]] && do_smart_slice "$tmp" "$ts" "$threshold"

  rm -f "$tmp" "$palette"

  local size; size=$(du -h "$out" | cut -f1)
  if [[ "$clipboard_mode" == "url" ]]; then
    upload_and_clip "$out" "GIF ($size)"
  else
    say "GIF saved" "${size} — $(basename "$out")" 5000
  fi
}

# ── screencast ────────────────────────────────────────────────────────────────
do_record() {
  local audio="$1" clipboard_mode="$2" smart_slice="$3" threshold="$4" X="$5" Y="$6" W="$7" H="$8"
  local ts out
  ts=$(date +%Y-%m-%d_%H-%M-%S)
  out="$SCREENCASTS_DIR/${ts}.mp4"

  local label
  [[ "$audio" == "yes" ]] && label="Recording + Audio" || label="Recording Screen"

  [[ $W -lt 2 || $H -lt 2 ]] && return

  local -a args

  if [[ "$PLATFORM" == "Darwin" ]]; then
    local scale screen_idx px py pw ph
    scale=$(mac_display_scale)
    screen_idx=$(mac_screen_index)
    px=$(( X * scale )); py=$(( Y * scale ))
    pw=$(( W * scale )); ph=$(( H * scale ))

    local input="${screen_idx}"
    [[ "$audio" == "yes" ]] && input="${screen_idx}:0"

    args=(-f avfoundation -r 30 -i "${input}"
          -filter:v "crop=${pw}:${ph}:${px}:${py},scale=${W}:-1:flags=lanczos"
          -vcodec libx264 -preset ultrafast -crf 18)
    [[ "$audio" == "yes" ]] && args+=(-acodec aac -b:a 128k)
  else
    args=(-f x11grab -r 30 -s "${W}x${H}" -i "${DISPLAY}+${X},${Y}")
    if [[ "$audio" == "yes" ]]; then
      local src
      src=$(pactl info 2>/dev/null | awk '/Default Source/{print $3}') || src="default"
      args+=(-f pulse -i "$src")
    fi
    args+=(-vcodec libx264 -preset ultrafast -crf 18)
    [[ "$audio" == "yes" ]] && args+=(-acodec aac -b:a 128k)
  fi

  args+=("$out" -y -loglevel quiet)

  ffmpeg "${args[@]}" &
  local fpid=$!

  wait_for_stop "$label"
  kill "$fpid" 2>/dev/null; wait "$fpid" 2>/dev/null || true

  local size; size=$(du -h "$out" | cut -f1)
  if [[ "$clipboard_mode" == "url" ]]; then
    upload_and_clip "$out" "Screencast ($size)"
  else
    say "Screencast saved" "${size} — $(basename "$out")" 5000
  fi

  [[ "$smart_slice" == "1" ]] && do_smart_slice "$out" "$ts" "$threshold"
}

# ── setup mode ────────────────────────────────────────────────────────────────
do_setup_s3() {
  local conf="$CONFIG_DIR/s3.conf"
  local BOLD="" DIM="" CYAN="" GREEN="" YELLOW="" RESET=""
  if [[ -t 1 ]]; then
    BOLD=$'\033[1m'; DIM=$'\033[2m'; CYAN=$'\033[36m'
    GREEN=$'\033[32m'; YELLOW=$'\033[33m'; RESET=$'\033[0m'
  fi

  echo ""
  echo "${CYAN}═══════════════════════════════════════════════════════════════${RESET}"
  echo "${BOLD}  S3 / R2 upload config${RESET} ${DIM}(optional — for URL clipboard mode)${RESET}"
  echo "${CYAN}═══════════════════════════════════════════════════════════════${RESET}"
  echo "  Copy shareable URLs instead of image bytes. Works with AWS S3,"
  echo "  Cloudflare R2, Backblaze B2, MinIO — anything S3-compatible."
  echo "  ${DIM}Secrets saved to ${conf} (chmod 600).${RESET}"
  echo ""

  local configure
  read -r -p "  Configure S3/R2 upload now? [y/N]: " configure </dev/tty
  if [[ ! "$configure" =~ ^[Yy]$ ]]; then
    echo "  ${DIM}Skipping. Re-run \`simple-screen-capture --setup\` any time.${RESET}"
    return 0
  fi

  local cur_endpoint="" cur_bucket="" cur_region="auto"
  local cur_key="" cur_secret="" cur_prefix="" cur_public="" cur_acl=""
  if [[ -f "$conf" ]]; then
    echo "  ${DIM}(existing config detected — press Enter to keep each value)${RESET}"
    # shellcheck disable=SC1090
    source "$conf" 2>/dev/null || true
    cur_endpoint="${S3_ENDPOINT:-}"
    cur_bucket="${S3_BUCKET:-}"
    cur_region="${S3_REGION:-auto}"
    cur_key="${S3_ACCESS_KEY_ID:-}"
    cur_secret="${S3_SECRET_ACCESS_KEY:-}"
    cur_prefix="${S3_PATH_PREFIX:-}"
    cur_public="${S3_PUBLIC_URL_BASE:-}"
    cur_acl="${S3_ACL:-}"
  fi
  echo ""

  local _ask_var _ask_label _ask_default _ask_hidden _ask_value _ask_display
  prompt_for() {
    _ask_var="$1"; _ask_label="$2"; _ask_default="$3"; _ask_hidden="${4:-}"
    if [[ -n "$_ask_default" ]]; then
      if [[ -n "$_ask_hidden" ]]; then
        _ask_display="${YELLOW}[keep existing]${RESET}"
      else
        _ask_display="${YELLOW}[${_ask_default}]${RESET}"
      fi
      printf '  %s %s: ' "$_ask_label" "$_ask_display"
    else
      printf '  %s: ' "$_ask_label"
    fi
    if [[ -n "$_ask_hidden" ]]; then
      read -r -s _ask_value </dev/tty; echo ""
    else
      read -r _ask_value </dev/tty
    fi
    printf -v "$_ask_var" '%s' "${_ask_value:-$_ask_default}"
  }

  prompt_for S3_ENDPOINT            "Endpoint URL"                "$cur_endpoint"
  prompt_for S3_BUCKET              "Bucket name"                 "$cur_bucket"
  prompt_for S3_REGION              "Region"                      "$cur_region"
  prompt_for S3_ACCESS_KEY_ID       "Access Key ID"               "$cur_key"
  prompt_for S3_SECRET_ACCESS_KEY   "Secret Access Key"           "$cur_secret" hidden
  prompt_for S3_PATH_PREFIX         "Path prefix (e.g. captures/)" "$cur_prefix"
  prompt_for S3_PUBLIC_URL_BASE     "Public URL base (CDN/domain)" "$cur_public"
  prompt_for S3_ACL                 "ACL (blank=R2, public-read=S3)" "$cur_acl"

  if [[ -z "$S3_ENDPOINT" || -z "$S3_BUCKET" || -z "$S3_ACCESS_KEY_ID" || -z "$S3_SECRET_ACCESS_KEY" ]]; then
    echo ""
    echo "  ${YELLOW}Required field empty — S3 config NOT saved.${RESET}"
    return 0
  fi

  mkdir -p "$CONFIG_DIR"
  (umask 077; cat > "$conf" <<EOF
# simple-screen-capture S3/R2 upload config
# Regenerate with: simple-screen-capture --setup
S3_ENDPOINT=$S3_ENDPOINT
S3_BUCKET=$S3_BUCKET
S3_REGION=$S3_REGION
S3_ACCESS_KEY_ID=$S3_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=$S3_SECRET_ACCESS_KEY
S3_PATH_PREFIX=$S3_PATH_PREFIX
S3_PUBLIC_URL_BASE=$S3_PUBLIC_URL_BASE
S3_ACL=$S3_ACL
EOF
  )
  chmod 600 "$conf"
  echo ""
  echo "  ${GREEN}✓${RESET} Saved ${conf}"
  echo "  ${DIM}Pick 'URL' in the capture panel's clipboard selector.${RESET}"
}

do_setup_shortcut() {
  if [[ "$PLATFORM" == "Darwin" ]]; then
    echo ""
    echo "To register a global keyboard shortcut on macOS, choose one option:"
    echo ""
    echo "Option 1 — Hammerspoon (recommended):"
    echo "  brew install --cask hammerspoon"
    echo "  Add to ~/.hammerspoon/init.lua:"
    echo "    hs.hotkey.bind({'ctrl','shift','alt'}, '4', function()"
    echo "      hs.execute('$(readlink -f "$0" 2>/dev/null || echo /usr/local/bin/simple-screen-capture)')"
    echo "    end)"
    echo ""
    echo "Option 2 — Automator Service:"
    echo "  Open Automator → New Quick Action → Run Shell Script"
    echo "  Enter: $(readlink -f "$0" 2>/dev/null || echo /usr/local/bin/simple-screen-capture)"
    echo "  Save as 'Screen Capture', then assign shortcut in"
    echo "  System Settings → Keyboard → Keyboard Shortcuts → Services"
    echo ""
    return 0
  fi

  echo "Setting up simple-screen-capture shortcut (Ctrl+Shift+Alt+4)..."

  local binding="<Primary><Shift><Alt>4"
  local schema="org.gnome.settings-daemon.plugins.media-keys"
  local base_path="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings"

  local existing target_slot=""
  existing=$(gsettings get "$schema" custom-keybindings)
  local cleaned
  cleaned=$(echo "$existing" | tr -d "[]'" | tr ',' '\n' | sed 's/^[[:space:]]*//' | grep -v '^$')
  while IFS= read -r entry; do
    [[ -z "$entry" ]] && continue
    local entry_binding
    entry_binding=$(gsettings get "${schema}.custom-keybinding:${entry}" binding 2>/dev/null || true)
    entry_binding=$(echo "$entry_binding" | tr -d "'")
    if [[ "$entry_binding" == "$binding" ]]; then
      target_slot="$entry"
      break
    fi
  done <<< "$cleaned"

  if [[ -n "$target_slot" ]]; then
    echo "  Found existing slot at ${target_slot} — updating in-place"
    dconf write "${target_slot}name"    "'Simple Screen Capture'"
    dconf write "${target_slot}command" "'/usr/bin/simple-screen-capture'"
    dconf write "${target_slot}binding" "'${binding}'"
  else
    local slot_name="simple-screen-capture"
    local slot_path="${base_path}/${slot_name}/"
    local updated=()
    while IFS= read -r entry; do
      [[ -z "$entry" ]] && updated+=("'${entry}'")
    done <<< "$cleaned"
    updated+=("'${slot_path}'")
    local new_list
    new_list="[$(IFS=,; echo "${updated[*]:-}")]"
    gsettings set "$schema" custom-keybindings "$new_list"
    dconf write "${slot_path}name"    "'Simple Screen Capture'"
    dconf write "${slot_path}command" "'/usr/bin/simple-screen-capture'"
    dconf write "${slot_path}binding" "'${binding}'"
    echo "  GNOME custom keybinding registered (${slot_path})"
  fi

  echo ""
  echo "Done. Press Ctrl+Shift+Alt+4 to open the capture panel."
}

do_setup() {
  do_setup_shortcut
  do_setup_s3
}

# ── export / import encrypted config ──────────────────────────────────────────
do_export_config() {
  local conf="$CONFIG_DIR/s3.conf"
  if [[ ! -f "$conf" ]]; then
    echo "capture: no S3 config at $conf — run --setup first" >&2
    exit 1
  fi
  command -v openssl &>/dev/null || { echo "capture: openssl required" >&2; exit 1; }

  local BOLD="" DIM="" YELLOW="" RESET=""
  if [[ -t 2 ]]; then
    BOLD=$'\033[1m'; DIM=$'\033[2m'; YELLOW=$'\033[33m'; RESET=$'\033[0m'
  fi

  {
    echo ""
    echo "${BOLD}Export encrypted R2 config for team sharing${RESET}"
    echo "${YELLOW}Warning:${RESET} anyone with the passphrase + this ciphertext gets full"
    echo "R2 credentials (read/write/delete your entire bucket). Use a strong"
    echo "passphrase, rotate when a teammate leaves, and prefer a path-scoped"
    echo "R2 API token over a global one."
    echo ""
  } >&2

  local pass pass2
  read -r -s -p "Passphrase (≥12 chars): " pass  </dev/tty; echo "" >&2
  read -r -s -p "Confirm:                " pass2 </dev/tty; echo "" >&2
  if [[ "$pass" != "$pass2" ]]; then
    echo "capture: passphrases don't match" >&2; exit 1
  fi
  if (( ${#pass} < 12 )); then
    echo "capture: passphrase too short (min 12)" >&2; exit 1
  fi

  export _CAP_PASS="$pass"
  openssl enc -aes-256-cbc -pbkdf2 -iter 600000 -salt -a -A \
    -in "$conf" -pass env:_CAP_PASS \
    || { unset _CAP_PASS; echo "capture: encryption failed" >&2; exit 1; }
  echo ""
  unset _CAP_PASS

  {
    echo "" >&2
    echo "${DIM}Share the ciphertext above + passphrase with your team (via password manager).${RESET}" >&2
    echo "${DIM}Teammates install with:${RESET}" >&2
    echo "" >&2
    echo "  CAPTURE_CONFIG='<paste-ciphertext>' bash <(curl -fsSL https://github.com/KerryRitter/simple-screen-capture/releases/latest/download/install.sh)" >&2
  } >&2
}

do_import_config() {
  local src="${1:-}"
  command -v openssl &>/dev/null || { echo "capture: openssl required" >&2; exit 1; }

  local ciphertext
  if [[ -z "$src" || "$src" == "-" ]]; then
    echo "Paste encrypted config (single line, press Enter when done):" >&2
    read -r ciphertext </dev/tty
  elif [[ "$src" =~ ^https?:// ]]; then
    command -v curl &>/dev/null || { echo "capture: curl required for URL import" >&2; exit 1; }
    ciphertext=$(curl -fsSL "$src") || { echo "capture: fetch failed: $src" >&2; exit 1; }
  elif [[ -f "$src" ]]; then
    ciphertext=$(cat "$src")
  elif [[ "$src" =~ ^U2FsdGVkX1 ]]; then
    ciphertext="$src"
  else
    echo "capture: not a URL, file, or ciphertext: $src" >&2; exit 1
  fi

  local pass
  if [[ -n "${CAPTURE_PASSPHRASE:-}" ]]; then
    pass="$CAPTURE_PASSPHRASE"
  else
    read -r -s -p "Passphrase: " pass </dev/tty; echo "" >&2
  fi

  mkdir -p "$CONFIG_DIR"
  local conf="$CONFIG_DIR/s3.conf"
  local tmp; tmp=$(mktemp)
  trap 'rm -f "$tmp"' EXIT

  export _CAP_PASS="$pass"
  if ! printf '%s\n' "$ciphertext" \
      | openssl enc -aes-256-cbc -pbkdf2 -iter 600000 -a -d \
          -pass env:_CAP_PASS > "$tmp" 2>/dev/null; then
    unset _CAP_PASS
    echo "capture: decryption failed (wrong passphrase or corrupted ciphertext)" >&2
    exit 1
  fi
  unset _CAP_PASS

  if ! grep -q '^S3_ENDPOINT=' "$tmp"; then
    echo "capture: decrypted content doesn't look like an s3.conf" >&2; exit 1
  fi

  (umask 077; cp "$tmp" "$conf")
  chmod 600 "$conf"
  echo "  ✓ Imported config → $conf" >&2
}

# ── main ──────────────────────────────────────────────────────────────────────
case "${1:-}" in
  --setup)            do_setup;                     exit 0 ;;
  --setup-shortcut)   do_setup_shortcut;            exit 0 ;;
  --setup-s3)         do_setup_s3;                  exit 0 ;;
  --export-config)    do_export_config;             exit 0 ;;
  --import-config)    do_import_config "${2:-}";    exit 0 ;;
esac

# Resolve clipboard mode from config. If unset, default to 'url' when S3 is
# configured, else 'binary'. File is plain text: "url" | "binary" | "base64".
get_clipboard_mode() {
  local v
  v=$(tr -d '[:space:]' < "$CONFIG_DIR/clipboard_mode" 2>/dev/null || true)
  if [[ -z "$v" ]]; then
    [[ -f "$CONFIG_DIR/s3.conf" ]] && v="url" || v="binary"
  fi
  case "$v" in url|binary|base64) echo "$v" ;; *) echo "binary" ;; esac
}

if [[ "$PLATFORM" == "Darwin" ]]; then
  # Use macOS's native selection UI (screencapture -i -s). Tk-based overlays
  # have proved unreliable across Tk/macOS combinations — the native tool is
  # pixel-perfect, always available, and behaves like Cmd+Shift+4.
  clipboard_mode=$(get_clipboard_mode)
  tmp=$(mktemp /tmp/capture-XXXXXX.png)
  ts=$(date +%Y-%m-%d_%H-%M-%S)
  out="$SCREENSHOTS_DIR/${ts}.png"

  # -i interactive, -s drag-region only (no window picker), -x silent
  screencapture -i -s -x "$tmp" 2>/dev/null
  if [[ ! -s "$tmp" ]]; then
    rm -f "$tmp"
    exit 0
  fi

  orig=$(wc -c < "$tmp")
  command -v optipng &>/dev/null && optipng -quiet -o2 "$tmp"
  comp=$(wc -c < "$tmp")
  pct=$(( (orig - comp) * 100 / orig ))
  cp "$tmp" "$out"

  case "$clipboard_mode" in
    url)    upload_and_clip "$out" "Screenshot" ;;
    base64) clip_base64 "$tmp"; say "Screenshot" "Base64 copied — ${comp}B (−${pct}%)" ;;
    *)      clip_image  "$tmp"; say "Screenshot" "Image copied — ${comp}B (−${pct}%)"  ;;
  esac
  rm -f "$tmp"
  exit 0
fi

result=$("${SCRIPT_DIR}/capture-region" 2>/tmp/capture-region.log) || true
[[ -z "$result" ]] && exit 0

read -r action clipboard smart_slice threshold X Y W H <<< "$result"
[[ -z "${H:-}" ]] && exit 0

case "$action" in
  screenshot) do_screenshot "$clipboard"                           "$X" "$Y" "$W" "$H" ;;
  gif)        do_gif        "$clipboard" "$smart_slice" "$threshold" "$X" "$Y" "$W" "$H" ;;
  screen)     do_record "no"  "$clipboard" "$smart_slice" "$threshold" "$X" "$Y" "$W" "$H" ;;
  audio)      do_record "yes" "$clipboard" "$smart_slice" "$threshold" "$X" "$Y" "$W" "$H" ;;
esac
