#!/usr/bin/python3
"""Full-screen region selector with integrated capture menu.

Click-and-drag anywhere to redraw the region; drag inside to move; drag edges/corners to resize.
The bottom toolbar switches mode and tweaks per-mode settings.

Emits on confirm:
    MODE CLIPBOARD_MODE SMART_SLICE THRESHOLD X Y W H

Exits silently on cancel.
"""
import gi, sys, os
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk, GLib

CONFIG_DIR       = os.path.expanduser('~/.config/capture')
CLIP_MODE_FILE   = os.path.join(CONFIG_DIR, 'clipboard_mode')
SMART_SLICE_FILE = os.path.join(CONFIG_DIR, 'smart_slice')
THRESHOLD_FILE   = os.path.join(CONFIG_DIR, 'smart_slice_threshold')
LAST_MODE_FILE   = os.path.join(CONFIG_DIR, 'last_mode')

EDGE         = 14
DELAY_MS     = 160
MIN_NEW_SIZE = 10

MODES = [
    ('screenshot', '📸', 'Screenshot', '📸  Capture'),
    ('gif',        '🎞', 'GIF',         '⏺  Record'),
    ('screen',     '🎬', 'Screen',      '🎬  Record'),
    ('audio',      '🎤', 'Audio',       '🎤  Record'),
]


def _read(path, default):
    try:
        return open(path).read().strip()
    except Exception:
        return default

def _write(path, value):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(path, 'w') as f:
        f.write(str(value))

def get_clipboard_mode():
    v = _read(CLIP_MODE_FILE, 'base64')
    return v if v in ('base64', 'binary') else 'base64'

def get_smart_slice():
    return _read(SMART_SLICE_FILE, '0') == '1'

def get_threshold():
    try:
        return max(0.02, min(0.25, float(_read(THRESHOLD_FILE, '0.07'))))
    except ValueError:
        return 0.07

def get_last_mode():
    v = _read(LAST_MODE_FILE, 'screenshot')
    return v if v in ('screenshot', 'gif', 'screen', 'audio') else 'screenshot'

def _region_key(mode):
    return 'last_region_screen' if mode == 'audio' else f'last_region_{mode}'

def get_last_region_for(mode):
    path = os.path.join(CONFIG_DIR, _region_key(mode))
    try:
        parts = open(path).read().strip().split()
        if len(parts) == 4:
            return tuple(int(p) for p in parts)
    except Exception:
        pass
    return None


class RegionSelector(Gtk.Window):
    def __init__(self):
        super().__init__(type=Gtk.WindowType.TOPLEVEL)

        self.mode           = get_last_mode()
        self.clipboard_mode = get_clipboard_mode()
        self.smart_slice    = get_smart_slice()
        self.threshold      = get_threshold()

        self.set_decorated(False)
        self.set_resizable(False)
        self.set_keep_above(True)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        self.set_can_focus(True)

        screen = self.get_screen()
        visual = screen.get_rgba_visual()
        if visual:
            self.set_visual(visual)
        self.set_app_paintable(True)

        # Target the monitor the cursor is on; we'll fullscreen onto it after show.
        display = Gdk.Display.get_default()
        root    = Gdk.get_default_root_window()
        _, cx, cy, _ = root.get_pointer()
        monitor = display.get_monitor_at_point(cx, cy)
        geo     = monitor.get_geometry()
        self.mon_x, self.mon_y = geo.x, geo.y
        self.scr_w, self.scr_h = geo.width, geo.height

        self._monitor_num = 0
        for i in range(display.get_n_monitors()):
            if display.get_monitor(i) == monitor:
                self._monitor_num = i
                break

        self.set_default_size(self.scr_w, self.scr_h)

        # Initial selection in window-local coords (stored last_region is in screen coords)
        last_region = get_last_region_for(self.mode)
        if last_region:
            rx, ry, rw, rh = last_region
            self.sel_x = rx - self.mon_x
            self.sel_y = ry - self.mon_y
            self.sel_w, self.sel_h = rw, rh
        else:
            w, h = 720, 450
            self.sel_x = max(0, (self.scr_w - w) // 2)
            self.sel_y = max(0, (self.scr_h - h) // 2)
            self.sel_w, self.sel_h = w, h

        self.drag_mode       = None
        self.drag_origin     = (0, 0)
        self.drag_start_rect = None
        self.drag_was_new    = False

        self.connect('delete-event',    lambda *_: Gtk.main_quit())
        self.connect('key-press-event', self._on_key)

        self._build_ui()
        self._apply_css()
        self._sync_mode()
        self._reposition_toolbar()

    # ── UI ────────────────────────────────────────────────────────────────────
    def _build_ui(self):
        overlay = Gtk.Overlay()
        self.add(overlay)

        self.da = Gtk.DrawingArea()
        self.da.add_events(
            Gdk.EventMask.BUTTON_PRESS_MASK   |
            Gdk.EventMask.BUTTON_RELEASE_MASK |
            Gdk.EventMask.POINTER_MOTION_MASK
        )
        self.da.connect('draw',                 self._on_draw)
        self.da.connect('button-press-event',   self._on_press)
        self.da.connect('button-release-event', self._on_release)
        self.da.connect('motion-notify-event',  self._on_motion)
        overlay.add(self.da)

        self._build_toolbar(overlay)

    def _build_toolbar(self, overlay):
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        outer.set_halign(Gtk.Align.CENTER)
        outer.set_valign(Gtk.Align.END)
        outer.set_margin_bottom(28)
        outer.set_margin_top(28)
        overlay.add_overlay(outer)
        overlay.set_overlay_pass_through(outer, False)
        self.toolbar = outer

        bar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        bar.set_name('toolbar')
        outer.pack_start(bar, False, False, 0)

        # ── mode tabs ────────────────────────────────────────────────────────
        mode_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
        mode_box.set_name('mode-box')
        self._mode_buttons = {}
        for mode_id, icon, label, _ in MODES:
            btn = Gtk.Button()
            btn.set_name('mode-btn')
            lbl = Gtk.Label(label=f'{icon}  {label}')
            lbl.set_name('mode-btn-lbl')
            btn.add(lbl)
            btn.connect('clicked', lambda _w, m=mode_id: self._set_mode(m))
            mode_box.pack_start(btn, False, False, 0)
            self._mode_buttons[mode_id] = btn
        bar.pack_start(mode_box, False, False, 0)

        bar.pack_start(self._make_vsep(), False, False, 0)

        # ── contextual settings (swapped on mode change) ─────────────────────
        self.ctx_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        self.ctx_box.set_name('ctx-box')
        bar.pack_start(self.ctx_box, False, False, 0)

        bar.pack_start(self._make_vsep(), False, False, 0)

        # ── action buttons ───────────────────────────────────────────────────
        act_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        act_box.set_name('act-box')

        self.cancel_btn = Gtk.Button(label='✕  Cancel')
        self.cancel_btn.set_name('cancel-btn')
        self.cancel_btn.connect('clicked', lambda *_: Gtk.main_quit())
        act_box.pack_start(self.cancel_btn, False, False, 0)

        self.capture_btn = Gtk.Button(label='📸  Capture')
        self.capture_btn.set_name('capture-btn')
        self.capture_btn.connect('clicked', self._confirm)
        act_box.pack_start(self.capture_btn, False, False, 0)

        bar.pack_start(act_box, False, False, 0)

    def _make_vsep(self):
        sep = Gtk.Box()
        sep.set_name('vsep')
        sep.set_size_request(1, -1)
        return sep

    # ── contextual sections ───────────────────────────────────────────────────
    def _build_screenshot_ctx(self):
        lbl = Gtk.Label(label='Clipboard')
        lbl.set_name('ctx-lbl')
        self.ctx_box.pack_start(lbl, False, False, 0)

        self._clip_b64_btn = Gtk.Button(label='Base64')
        self._clip_b64_btn.connect('clicked', lambda *_: self._set_clipboard('base64'))
        self.ctx_box.pack_start(self._clip_b64_btn, False, False, 0)

        self._clip_bin_btn = Gtk.Button(label='PNG')
        self._clip_bin_btn.connect('clicked', lambda *_: self._set_clipboard('binary'))
        self.ctx_box.pack_start(self._clip_bin_btn, False, False, 0)

        self._refresh_clipboard_buttons()

    def _build_recording_ctx(self):
        self._slice_cb = Gtk.CheckButton(label='Smart Slice')
        self._slice_cb.set_name('slice-cb')
        self._slice_cb.set_active(self.smart_slice)
        self._slice_cb.connect('toggled', self._on_smart_slice_toggled)
        self.ctx_box.pack_start(self._slice_cb, False, False, 0)

        self._sens_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        sens_lbl = Gtk.Label(label='Sensitivity')
        sens_lbl.set_name('ctx-lbl')
        self._sens_box.pack_start(sens_lbl, False, False, 0)

        self._sens_scale = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, 0.02, 0.25, 0.01)
        self._sens_scale.set_name('sens-scale')
        self._sens_scale.set_value(self.threshold)
        self._sens_scale.set_draw_value(False)
        self._sens_scale.set_size_request(140, -1)
        self._sens_scale.set_inverted(True)  # right = more sensitive (lower threshold)
        self._sens_scale.connect('value-changed', self._on_threshold_change)
        self._sens_box.pack_start(self._sens_scale, False, False, 0)

        self.ctx_box.pack_start(self._sens_box, False, False, 0)

    def _sync_mode(self):
        for mid, btn in self._mode_buttons.items():
            btn.set_name('mode-btn-active' if mid == self.mode else 'mode-btn')

        for child in self.ctx_box.get_children():
            self.ctx_box.remove(child)
        if self.mode == 'screenshot':
            self._build_screenshot_ctx()
        else:
            self._build_recording_ctx()

        label = next(bl for mid, _i, _l, bl in MODES if mid == self.mode)
        self.capture_btn.set_label(label)

        self.ctx_box.show_all()
        if self.mode != 'screenshot':
            self._sens_box.set_visible(self.smart_slice)

    def _set_mode(self, mode):
        if mode == self.mode:
            return
        # Recall this mode's last region (stored in screen coords → convert)
        last = get_last_region_for(mode)
        self.mode = mode
        if last:
            rx, ry, rw, rh = last
            self.sel_x, self.sel_y = rx - self.mon_x, ry - self.mon_y
            self.sel_w, self.sel_h = rw, rh
            self._reposition_toolbar()
            self.da.queue_draw()
        self._sync_mode()

    def _set_clipboard(self, mode):
        self.clipboard_mode = mode
        self._refresh_clipboard_buttons()

    def _refresh_clipboard_buttons(self):
        if self.clipboard_mode == 'base64':
            self._clip_b64_btn.set_name('fmt-active')
            self._clip_bin_btn.set_name('fmt-btn')
        else:
            self._clip_b64_btn.set_name('fmt-btn')
            self._clip_bin_btn.set_name('fmt-active')

    def _on_smart_slice_toggled(self, cb):
        self.smart_slice = cb.get_active()
        self._sens_box.set_visible(self.smart_slice)

    def _on_threshold_change(self, scale):
        self.threshold = scale.get_value()

    # ── toolbar auto-flip (bottom/top based on selection) ─────────────────────
    def _reposition_toolbar(self):
        toolbar_top = self.scr_h - 100
        if self.sel_y + self.sel_h > toolbar_top:
            self.toolbar.set_valign(Gtk.Align.START)
        else:
            self.toolbar.set_valign(Gtk.Align.END)

    # ── CSS ───────────────────────────────────────────────────────────────────
