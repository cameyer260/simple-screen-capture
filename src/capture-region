            """
            p = Gtk.CssProvider()
            p.load_from_data(css)
            Gtk.StyleContext.add_provider_for_screen(
                self.get_screen(), p, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        def _on_draw(self, da, cr):
            a = da.get_allocation()
            W, H = a.width, a.height
            sx, sy, sw, sh = self.sel_x, self.sel_y, self.sel_w, self.sel_h
            cx1 = max(0, min(sx, W));      cy1 = max(0, min(sy, H))
            cx2 = max(0, min(sx+sw, W));   cy2 = max(0, min(sy+sh, H))
            cr.set_source_rgba(0, 0, 0, 0.45)
            cr.rectangle(0, 0, W, cy1);               cr.fill()
            cr.rectangle(0, cy2, W, H-cy2);           cr.fill()
            cr.rectangle(0, cy1, cx1, cy2-cy1);       cr.fill()
            cr.rectangle(cx2, cy1, W-cx2, cy2-cy1);   cr.fill()
            if sw < 2 or sh < 2:
                return False
            cr.set_source_rgba(0.537, 0.706, 0.980, 0.95)
            cr.set_line_width(2.0); cr.set_dash([12, 6])
            cr.rectangle(sx+1, sy+1, sw-2, sh-2); cr.stroke()
            cr.set_dash([])
            cr.set_source_rgba(0.537, 0.706, 0.980, 1.0)
            sq = 10
            for hx, hy in [(sx,sy),(sx+sw,sy),(sx,sy+sh),(sx+sw,sy+sh)]:
                cr.rectangle(hx-sq/2, hy-sq/2, sq, sq); cr.fill()
            text = f'{sw} × {sh}'
            cr.select_font_face('Sans'); cr.set_font_size(13)
            ext  = cr.text_extents(text)
            bw, bh = ext.width+14, 22
            bx = sx; by = sy-bh-6
            if by < 2: by = sy+6
            cr.set_source_rgba(0.118, 0.118, 0.180, 0.92)
            cr.rectangle(bx, by, bw, bh); cr.fill()
            cr.set_source_rgba(0.804, 0.839, 0.957, 1.0)
            cr.move_to(bx+7, by+bh-7); cr.show_text(text)
            return False

        def _hit_test(self, x, y):
            sx, sy, sw, sh = self.sel_x, self.sel_y, self.sel_w, self.sel_h
            if not (sx-EDGE <= x <= sx+sw+EDGE and sy-EDGE <= y <= sy+sh+EDGE):
                return 'new'
            nl = x <= sx+EDGE; nr = x >= sx+sw-EDGE
            nt = y <= sy+EDGE; nb = y >= sy+sh-EDGE
            if nt and nl: return 'nw'
            if nt and nr: return 'ne'
            if nb and nl: return 'sw'
            if nb and nr: return 'se'
            if nl: return 'w'
            if nr: return 'e'
            if nt: return 'n'
            if nb: return 's'
            return 'move'

        _CURS = {
            'move':'move','nw':'nw-resize','ne':'ne-resize','sw':'sw-resize','se':'se-resize',
            'w':'w-resize','e':'e-resize','n':'n-resize','s':'s-resize','new':'crosshair',
        }

        def _set_cursor(self, mode):
            name = self._CURS.get(mode, 'default')
            disp = self.get_display(); gw = self.da.get_window()
            if not (disp and gw): return
            try:    gw.set_cursor(Gdk.Cursor.new_from_name(disp, name))
            except: pass

        def _on_press(self, widget, event):
            if event.button != 1: return False
            x, y = event.x, event.y
            mode = self._hit_test(x, y)
            self.drag_origin = (x, y)
            self.drag_start_rect = (self.sel_x, self.sel_y, self.sel_w, self.sel_h)
            self.drag_was_new = (mode == 'new')
            if mode == 'new':
                self.sel_x, self.sel_y = int(x), int(y)
                self.sel_w, self.sel_h = 0, 0
                self.drag_start_rect = (int(x), int(y), 0, 0)
                self.drag_mode = 'se'
            else:
                self.drag_mode = mode
            self._set_cursor(self.drag_mode)
            self.da.queue_draw()
            return True

        def _on_motion(self, widget, event):
            if self.drag_mode is None:
                self._set_cursor(self._hit_test(event.x, event.y))
                return False
            dx = event.x-self.drag_origin[0]; dy = event.y-self.drag_origin[1]
            ox, oy, ow, oh = self.drag_start_rect
            if self.drag_mode == 'move':
                nx, ny, nw, nh = int(ox+dx), int(oy+dy), ow, oh
            else:
                nx, ny, nw, nh = ox, oy, ow, oh
                if self.drag_mode in ('w','nw','sw'): nx=int(ox+dx); nw=int(ow-dx)
                elif self.drag_mode in ('e','ne','se'): nw=int(ow+dx)
                if self.drag_mode in ('n','nw','ne'): ny=int(oy+dy); nh=int(oh-dy)
                elif self.drag_mode in ('s','sw','se'): nh=int(oh+dy)
                if nw<0: nx+=nw; nw=-nw
                if nh<0: ny+=nh; nh=-nh
            self.sel_x, self.sel_y, self.sel_w, self.sel_h = nx, ny, nw, nh
            self._reposition_toolbar()
            self.da.queue_draw()
            return True

        def _on_release(self, widget, event):
            if self.drag_was_new and (self.sel_w<MIN_NEW_SIZE or self.sel_h<MIN_NEW_SIZE):
                self.sel_x, self.sel_y, self.sel_w, self.sel_h = self.drag_start_rect
                self.da.queue_draw()
            self.drag_mode = None
            self._reposition_toolbar()
            self._set_cursor(self._hit_test(event.x, event.y))
            return True

        def _on_key(self, widget, event):
            if event.keyval == Gdk.KEY_Escape:
                Gtk.main_quit()
            elif event.keyval in (Gdk.KEY_Return, Gdk.KEY_KP_Enter):
                self._confirm()

        def _confirm(self, *_):
            self.hide()
            GLib.timeout_add(DELAY_MS, self._emit)

        def _emit(self):
            sx = self.sel_x + self.mon_x
            sy = self.sel_y + self.mon_y
            self._result = _save_result(
                self.mode, self.clipboard_mode, self.smart_slice, self.threshold,
                sx, sy, self.sel_w, self.sel_h)
            Gtk.main_quit()
            return False

    win = RegionSelector()
    win.show_all()
    win.fullscreen_on_monitor(win.get_screen(), win._monitor_num)
    win.present()
    Gtk.main()
    return win._result


