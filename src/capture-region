# macOS / tkinter
# ══════════════════════════════════════════════════════════════════════════════

def run_mac():
    import tkinter as tk
    import subprocess, tempfile

    class RegionSelector:
        def __init__(self):
            self.mode           = get_last_mode()
            self.clipboard_mode = get_clipboard_mode()
            self.smart_slice    = get_smart_slice()
            self.threshold      = get_threshold()
            self.drag_mode      = None
            self.drag_origin    = (0, 0)
            self.drag_start_rect = None
            self.drag_was_new   = False
            self._result        = None

            self._root = tk.Tk()
            self._root.withdraw()

            sw = self._root.winfo_screenwidth()
            sh = self._root.winfo_screenheight()
            self.scr_w, self.scr_h = sw, sh
            self.mon_x, self.mon_y = 0, 0

            self._root.geometry(f'{sw}x{sh}+0+0')
            self._root.wm_attributes('-topmost', True)
            self._root.overrideredirect(True)

            # Fake transparency using background screenshot
            self._bg_img = None
            bg_file = tempfile.mktemp(suffix='.png')
            try:
                r = subprocess.run(['screencapture', '-x', bg_file],
                                   capture_output=True, timeout=5)
                if r.returncode == 0 and os.path.exists(bg_file):
                    img = tk.PhotoImage(file=bg_file)
                    scale = round(img.width() / sw) if sw else 1
                    if scale > 1:
                        img = img.subsample(scale, scale)
                    self._bg_img = img
            except Exception:
                pass
            finally:
                try: os.unlink(bg_file)
                except: pass

            if self._bg_img is None:
                self._root.wm_attributes('-alpha', 0.35)

            self._canvas = tk.Canvas(self._root, bg='black',
                                     highlightthickness=0, cursor='crosshair')
            self._canvas.pack(fill='both', expand=True)
            if self._bg_img:
                self._canvas.create_image(0, 0, anchor='nw',
                                          image=self._bg_img, tags='bg')

            last_region = get_last_region_for(self.mode)
            if last_region:
                rx, ry, rw, rh = last_region
                self.sel_x, self.sel_y = rx, ry
                self.sel_w, self.sel_h = rw, rh
            else:
                w, h = 720, 450
                self.sel_x = max(0, (sw - w) // 2)
                self.sel_y = max(0, (sh - h) // 2)
                self.sel_w, self.sel_h = w, h

            self._build_toolbar(tk)

            self._canvas.bind('<ButtonPress-1>',   self._on_press)
            self._canvas.bind('<B1-Motion>',       self._on_motion)
            self._canvas.bind('<ButtonRelease-1>', self._on_release)
            self._canvas.bind('<Motion>',          self._on_hover)
            for widget in (self._root, self._canvas):
                widget.bind('<Escape>', lambda e: self._cancel())
                widget.bind('<Return>', lambda e: self._confirm())
                widget.bind('<KP_Enter>', lambda e: self._confirm())
            self._canvas.config(takefocus=True)
            self._redraw()

            # Show the window as borderless. overrideredirect(True) alone is flaky on
            # macOS Tk (often leaves a titlebar visible); the toggle forces Tk to
            # re-assert the frameless style after the window is mapped.
            self._root.update_idletasks()
            self._root.deiconify()
            self._root.overrideredirect(False)
            self._root.overrideredirect(True)
            self._root.lift()
            self._root.focus_force()
            self._canvas.focus_set()

        def _build_toolbar(self, tk):
            BG, ACCENT = '#181825', '#89b4fa'
            BTN_DIM = '#2a2a3a'

            tbw, tbh = 700, 52
            tx = max(0, (self.scr_w - tbw) // 2)
            # macOS Dock reserves ~80px at bottom (when visible); place toolbar above it.
            ty = self.scr_h - tbh - 110

            self._tb = tk.Frame(self._root, bg=BG, highlightthickness=1,
                                highlightbackground='#313244')
            self._tb.place(x=tx, y=ty, width=tbw, height=tbh)
            self._tb.lift()

            f = tk.Frame(self._tb, bg=BG)
            f.place(x=8, y=6, width=tbw-16, height=tbh-12)

            self._mode_btns = {}
            for mode_id, icon, label, _ in MODES:
                btn = tk.Button(
                    f, text=f'{icon} {label}',
                    bg=BTN_DIM, fg='#cdd6f4', activebackground=ACCENT,
                    activeforeground='#1e1e2e', relief='flat',
                    padx=8, pady=3, font=('Helvetica', 12), cursor='hand2',
                    command=lambda m=mode_id: self._set_mode(m)
                )
                btn.pack(side='left', padx=2)
                self._mode_btns[mode_id] = btn

            tk.Frame(f, bg='#313244', width=1).pack(side='left', fill='y', padx=6, pady=2)

            self._ctx = tk.Frame(f, bg=BG)
            self._ctx.pack(side='left', padx=2)

            tk.Frame(f, bg='#313244', width=1).pack(side='left', fill='y', padx=6, pady=2)

            tk.Button(
                f, text='✕ Cancel',
                bg=BTN_DIM, fg='#a6adc8', activebackground='#313244',
                activeforeground='#cdd6f4', relief='flat',
                padx=8, pady=3, font=('Helvetica', 12), cursor='hand2',
                command=self._cancel
            ).pack(side='left', padx=2)

            self._cap_btn = tk.Button(
                f, text='📸 Capture',
                bg=ACCENT, fg='#1e1e2e', activebackground='#a6c8fc',
                activeforeground='#1e1e2e', relief='flat',
                padx=12, pady=3, font=('Helvetica', 12, 'bold'),
                cursor='hand2', command=self._confirm
            )
            self._cap_btn.pack(side='left', padx=2)
            self._sync_mode()

        def _sync_mode(self):
            ACCENT, BTN_DIM = '#89b4fa', '#2a2a3a'
            for mid, btn in self._mode_btns.items():
                btn.configure(bg='#2a3a5a' if mid == self.mode else BTN_DIM,
                              fg=ACCENT if mid == self.mode else '#cdd6f4')
            for w in self._ctx.winfo_children():
                w.destroy()
            if self.mode == 'screenshot':
                self._build_screenshot_ctx()
            else:
                self._build_recording_ctx()
            self._cap_btn.configure(
                text=next(bl for mid, _i, _l, bl in MODES if mid == self.mode))

        def _build_screenshot_ctx(self):
            BG = '#181825'
            import tkinter as tk
            tk.Label(self._ctx, text='Clipboard:', bg=BG, fg='#a6adc8',
                     font=('Helvetica', 11)).pack(side='left', padx=(0, 4))
            self._clip_btns = {}
            for val, label in (('binary','Image'),('base64','Base64'),('url','URL')):
                btn = tk.Button(
                    self._ctx, text=label, bg='#2a2a3a', fg='#585b70',
                    relief='flat', padx=6, pady=2, font=('Helvetica', 11),
                    cursor='hand2', command=lambda v=val: self._set_clipboard(v)
                )
                btn.pack(side='left', padx=1)
                self._clip_btns[val] = btn
            self._refresh_clip_btns()

        def _build_recording_ctx(self):
            BG = '#181825'
            import tkinter as tk
            self._url_var = tk.BooleanVar(value=self.clipboard_mode == 'url')
            tk.Checkbutton(
                self._ctx, text='Copy URL', variable=self._url_var,
                bg=BG, fg='#cdd6f4', selectcolor='#313244', activebackground=BG,
                font=('Helvetica', 12), command=self._on_url_toggled
            ).pack(side='left', padx=4)
            self._slice_var = tk.BooleanVar(value=self.smart_slice)
            tk.Checkbutton(
                self._ctx, text='Smart Slice', variable=self._slice_var,
                bg=BG, fg='#cdd6f4', selectcolor='#313244', activebackground=BG,
                font=('Helvetica', 12), command=self._on_smart_slice_toggled
            ).pack(side='left', padx=4)

        def _refresh_clip_btns(self):
            for val, btn in self._clip_btns.items():
                btn.configure(bg='#2a3a5a' if val == self.clipboard_mode else '#2a2a3a',
                              fg='#89b4fa' if val == self.clipboard_mode else '#585b70')

        def _set_clipboard(self, mode):
            self.clipboard_mode = mode
            self._refresh_clip_btns()

        def _on_url_toggled(self):
            self.clipboard_mode = 'url' if self._url_var.get() else 'binary'

        def _on_smart_slice_toggled(self):
            self.smart_slice = self._slice_var.get()

        def _set_mode(self, mode):
            if mode == self.mode: return
            last = get_last_region_for(mode)
            self.mode = mode
            if last:
                rx, ry, rw, rh = last
                self.sel_x, self.sel_y = rx, ry
                self.sel_w, self.sel_h = rw, rh
                self._redraw()
            self._sync_mode()

        def _redraw(self):
            c = self._canvas
            c.delete('overlay')
            sw, sh = self.scr_w, self.scr_h
            sx, sy, sew, seh = self.sel_x, self.sel_y, self.sel_w, self.sel_h
            kw = dict(fill='black', stipple='gray50', outline='', tags='overlay')
            if sy > 0:         c.create_rectangle(0, 0, sw, sy, **kw)
            if sy+seh < sh:    c.create_rectangle(0, sy+seh, sw, sh, **kw)
            if sx > 0:         c.create_rectangle(0, sy, sx, sy+seh, **kw)
            if sx+sew < sw:    c.create_rectangle(sx+sew, sy, sw, sy+seh, **kw)
            if sew < 2 or seh < 2: return
            c.create_rectangle(sx+1, sy+1, sx+sew-1, sy+seh-1,
                               outline='#89b4fa', width=2, dash=(12,6), tags='overlay')
            sq = 10
            for hx, hy in [(sx,sy),(sx+sew,sy),(sx,sy+seh),(sx+sew,sy+seh)]:
                c.create_rectangle(hx-sq//2, hy-sq//2, hx+sq//2, hy+sq//2,
                                   fill='#89b4fa', outline='', tags='overlay')
            text = f'{sew} × {seh}'
            lx = sx; ly = sy-28 if sy > 28 else sy+8
            c.create_rectangle(lx, ly, lx+len(text)*8+14, ly+22,
                               fill='#1e1e2e', outline='', tags='overlay')
            c.create_text(lx+7, ly+11, text=text, fill='#cdd6f4',
                         anchor='w', font=('Helvetica', 13), tags='overlay')

        def _hit_test(self, x, y):
            sx, sy, sw, sh = self.sel_x, self.sel_y, self.sel_w, self.sel_h
            if not (sx-EDGE <= x <= sx+sw+EDGE and sy-EDGE <= y <= sy+sh+EDGE):
                return 'new'
            nl=x<=sx+EDGE; nr=x>=sx+sw-EDGE; nt=y<=sy+EDGE; nb=y>=sy+sh-EDGE
            if nt and nl: return 'nw'
            if nt and nr: return 'ne'
            if nb and nl: return 'sw'
            if nb and nr: return 'se'
            if nl: return 'w'
            if nr: return 'e'
            if nt: return 'n'
            if nb: return 's'
            return 'move'

        _CURS = {
            'move':'fleur','new':'crosshair',
            'nw':'top_left_corner','ne':'top_right_corner',
            'sw':'bottom_left_corner','se':'bottom_right_corner',
            'w':'left_side','e':'right_side','n':'top_side','s':'bottom_side',
        }

        def _set_cursor(self, mode):
            try: self._canvas.configure(cursor=self._CURS.get(mode, 'crosshair'))
            except: pass

        def _on_press(self, event):
            self._canvas.focus_set()
            x, y = event.x, event.y
            mode = self._hit_test(x, y)
            self.drag_origin = (x, y)
            self.drag_start_rect = (self.sel_x, self.sel_y, self.sel_w, self.sel_h)
            self.drag_was_new = (mode == 'new')
            if mode == 'new':
                self.sel_x, self.sel_y = int(x), int(y)
                self.sel_w, self.sel_h = 0, 0
                self.drag_start_rect = (int(x), int(y), 0, 0)
                self.drag_mode = 'se'
            else:
                self.drag_mode = mode
            self._set_cursor(self.drag_mode)
            self._redraw()

        def _on_motion(self, event):
            if self.drag_mode is None: return
            dx = event.x - self.drag_origin[0]
            dy = event.y - self.drag_origin[1]
            ox, oy, ow, oh = self.drag_start_rect
            if self.drag_mode == 'move':
                nx, ny, nw, nh = int(ox+dx), int(oy+dy), ow, oh
            else:
                nx, ny, nw, nh = ox, oy, ow, oh
                if self.drag_mode in ('w','nw','sw'): nx=int(ox+dx); nw=int(ow-dx)
                elif self.drag_mode in ('e','ne','se'): nw=int(ow+dx)
                if self.drag_mode in ('n','nw','ne'): ny=int(oy+dy); nh=int(oh-dy)
                elif self.drag_mode in ('s','sw','se'): nh=int(oh+dy)
                if nw<0: nx+=nw; nw=-nw
                if nh<0: ny+=nh; nh=-nh
            self.sel_x, self.sel_y, self.sel_w, self.sel_h = nx, ny, nw, nh
            self._redraw()

        def _on_release(self, event):
            if self.drag_was_new and (self.sel_w<MIN_NEW_SIZE or self.sel_h<MIN_NEW_SIZE):
                self.sel_x, self.sel_y, self.sel_w, self.sel_h = self.drag_start_rect
                self._redraw()
            self.drag_mode = None
            self._set_cursor(self._hit_test(event.x, event.y))

        def _on_hover(self, event):
            if self.drag_mode is None:
                self._set_cursor(self._hit_test(event.x, event.y))

        def _cancel(self):
            self._result = None
            self._root.quit()

        def _confirm(self, *_):
            if getattr(self, '_confirming', False):
                return
            self._confirming = True
            self._root.withdraw()
            self._root.after(DELAY_MS, self._emit)

        def _emit(self):
            self._result = _save_result(
                self.mode, self.clipboard_mode, self.smart_slice, self.threshold,
                self.sel_x + self.mon_x, self.sel_y + self.mon_y,
                self.sel_w, self.sel_h)
            self._root.quit()

    sel = RegionSelector()
    sel._root.mainloop()
    return sel._result


