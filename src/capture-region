#!/opt/homebrew/bin/python3
"""Full-screen region selector with integrated capture menu.

Click-and-drag to define region; drag inside to move; drag edges/corners to resize.
Emits on confirm:  MODE CLIPBOARD_MODE SMART_SLICE THRESHOLD X Y W H
Exits silently on cancel.
"""
import sys, os, platform

CONFIG_DIR       = os.path.expanduser('~/.config/capture')
CLIP_MODE_FILE   = os.path.join(CONFIG_DIR, 'clipboard_mode')
SMART_SLICE_FILE = os.path.join(CONFIG_DIR, 'smart_slice')
THRESHOLD_FILE   = os.path.join(CONFIG_DIR, 'smart_slice_threshold')
LAST_MODE_FILE   = os.path.join(CONFIG_DIR, 'last_mode')

EDGE         = 14
DELAY_MS     = 160
MIN_NEW_SIZE = 10

MODES = [
    ('screenshot', '📸', 'Screenshot', '📸  Capture'),
    ('gif',        '🎞', 'GIF',         '⏺  Record'),
    ('screen',     '🎬', 'Screen',      '🎬  Record'),
    ('audio',      '🎤', 'Audio',       '🎤  Record'),
]

# ── config helpers ────────────────────────────────────────────────────────────

def _read(path, default):
    try:    return open(path).read().strip()
    except: return default

def _write(path, value):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    open(path, 'w').write(str(value))

def get_clipboard_mode():
    # Default to 'url' when S3 is configured, so new users get upload mode out of the box.
    s3_configured = os.path.isfile(os.path.expanduser('~/.config/capture/s3.conf'))
    default = 'url' if s3_configured else 'base64'
    v = _read(CLIP_MODE_FILE, default)
    return v if v in ('base64', 'binary', 'url') else default

def get_smart_slice():
    return _read(SMART_SLICE_FILE, '0') == '1'

def get_threshold():
    try:    return max(0.02, min(0.25, float(_read(THRESHOLD_FILE, '0.07'))))
    except: return 0.07

def get_last_mode():
    v = _read(LAST_MODE_FILE, 'screenshot')
    return v if v in ('screenshot', 'gif', 'screen', 'audio') else 'screenshot'

def _region_key(mode):
    return 'last_region_screen' if mode == 'audio' else f'last_region_{mode}'

def get_last_region_for(mode):
    path = os.path.join(CONFIG_DIR, _region_key(mode))
    try:
        parts = open(path).read().strip().split()
        if len(parts) == 4:
            return tuple(int(p) for p in parts)
    except: pass
    return None

def _save_result(mode, clipboard_mode, smart_slice, threshold, sx, sy, sel_w, sel_h):
    w = sel_w + (sel_w % 2)
    h = sel_h + (sel_h % 2)
    _write(CLIP_MODE_FILE,   clipboard_mode)
    _write(SMART_SLICE_FILE, '1' if smart_slice else '0')
    _write(THRESHOLD_FILE,   f'{threshold:.3f}')
    _write(LAST_MODE_FILE,   mode)
    _write(os.path.join(CONFIG_DIR, _region_key(mode)), f'{sx} {sy} {sel_w} {sel_h}')
    smart = '1' if (smart_slice and mode != 'screenshot') else '0'
    return f'{mode} {clipboard_mode} {smart} {threshold:.3f} {sx} {sy} {w} {h}'


